# Database Configuration
MONGODB_URI=

# MySQL secondary storage (MongoDB sync cache)
# Local (with docker-compose.mysql.yml): mysql://elevate:elevate123@localhost:3306/elevate_dev
MYSQL_DATABASE_URL=

# Optional: disable automatic Mongo→MySQL sync interval (ms). Default 300000 (5 min)
# AUTO_SYNC_INTERVAL_MS=300000

# AI Assistant (MongoDB + LangChain + OpenRouter)
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_APP_NAME=Elevate HR
# Fallback if you prefer OpenAI directly instead of OpenRouter:
# OPENAI_API_KEY=

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=

# Credential encryption for tenant SMTP passwords (32+ chars recommended; falls back to JWT_SECRET)
ENCRYPTION_KEY=

# Platform owner access (comma-separated emails, or use super_admin role)
PLATFORM_OWNER_EMAILS=bellarinseth@gmail.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Email Configuration (optional - for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@elevate.com

# WebSMS Provider Configuration (Dispatch SMS)
WEBSMS_CLIENT_ID=
WEBSMS_API_KEY=
WEBSMS_ENDPOINT=https://sms.websms.co.ke/v1/onfonapps/sms:sendCampaign
WEBSMS_DEFAULT_SENDER_NAME=YourCompany

# Dispatch SMS defaults
DISPATCH_DEFAULT_COUNTRY_CODE=254
DISPATCH_OFFICE_NUMBER=

# M-Pesa Daraja
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://your-api-domain/api/mpesa/callback
MPESA_CALLBACK_TOKEN=
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_DEFAULT_COUNTRY_CODE=254

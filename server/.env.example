# Database Configuration
MONGODB_URI=

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Email Configuration (optional - for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@elevate.com

# Africa's Talking SMS (dispatch notifications)
# Use your live username in production (do not use "sandbox" when NODE_ENV=production)
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=
AFRICASTALKING_SENDER_ID=
AFRICASTALKING_BASE_URL=https://api.africastalking.com/version1/messaging
AFRICASTALKING_CALLBACK_TOKEN=

# Dispatch SMS defaults
DISPATCH_DEFAULT_COUNTRY_CODE=254
DISPATCH_OFFICE_NUMBER=

# M-Pesa Daraja
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://your-api-domain/api/mpesa/callback
MPESA_CALLBACK_TOKEN=
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_DEFAULT_COUNTRY_CODE=254

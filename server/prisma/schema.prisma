// Prisma schema for MySQL secondary storage layer
generator client {
  provider = "prisma-client-js"
  // Include binaryTargets for deployment environments. Add other targets if needed.
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "mysql"
  url      = env("MYSQL_DATABASE_URL")
}

// User table (synced from MongoDB)
model User {
  id                String   @id @default(uuid())
  mongoId           String   @unique @map("mongo_id")
  org_id            String
  email             String   @unique
  firstName         String
  lastName          String
  role              String   // "super_admin" | "company_admin" | "admin" | "manager" | "employee" | "hr"
  status            String   // "active" | "inactive"
  employee_id       String?  @unique
  password          String   // hashed password for secondary auth
  phone             String?
  department        String?
  manager_id        String?
  profileImage      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  isActive          Boolean  @default(true)

  @@index([org_id])
  @@index([email])
  @@index([role])
  @@map("User")
}

// Company table (synced from MongoDB)
model Company {
  id                String   @id @default(uuid())
  mongoId           String   @unique @map("mongo_id")
  name              String
  slug              String   @unique
  email             String
  phone             String?
  website           String?
  industry          String?
  employeeCount     Int?
  status            String   @default("active") // "active" | "inactive"
  isFrozen          Boolean  @default(false)
  primaryColor      String   @default("#667eea")
  secondaryColor    String   @default("#764ba2")
  logo              String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([slug])
  @@index([status])
  @@map("Company")
}

// Audit Log - track all significant changes
model AuditLog {
  id                String   @id @default(uuid())
  userId            String
  org_id            String
  entity            String   // "User", "Company", "Stock", "Product" etc
  action            String   // "CREATE", "UPDATE", "DELETE"
  entityId          String
  mongoEntityId      String?
  oldValues         Json?
  newValues         Json?
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime @default(now())

  @@index([userId])
  @@index([org_id])
  @@index([entity])
  @@index([action])
  @@index([createdAt])
  @@map("AuditLog")
}

// Session tracking for authentication
model Session {
  id                String   @id @default(uuid())
  userId            String
  org_id            String
  token             String   @unique
  ipAddress         String?
  userAgent         String?
  expiresAt         DateTime
  createdAt         DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("Session")
}

// Analytics snapshot - denormalized from MongoDB
model AnalyticsSnapshot {
  id                String   @id @default(uuid())
  org_id            String
  date              DateTime
  totalUsers        Int      @default(0)
  activeUsers       Int      @default(0)
  totalCompanies    Int      @default(0)
  totalProducts     Int      @default(0)
  totalSales        Int      @default(0)
  totalRevenue      Float    @default(0)
  data              Json?    // Additional metrics as JSON
  createdAt         DateTime @default(now())

  @@unique([org_id, date])
  @@index([org_id])
  @@index([date])
  @@map("AnalyticsSnapshot")
}


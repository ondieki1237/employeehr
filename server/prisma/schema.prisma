model StockQuotation {
  id                String   @id @default(cuid())
  orgId             String
  org               Company  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  quotationNumber   String
  clientId          String
  client            StockClient @relation(fields: [clientId], references: [id], onDelete: Restrict)
  
  items             Json     // Array of {productId, quantity, unitPrice}
  totalAmount       Float
  status            String   @default("draft") // draft, sent, accepted, rejected, expired
  validUntil        DateTime?
  notes             String?  @db.Text
  
  createdBy         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@unique([orgId, quotationNumber])
  @@index([clientId])
}

model StockInvoice {
  id                String   @id @default(cuid())
  orgId             String
  org               Company  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invoiceNumber     String
  clientId          String
  client            StockClient @relation(fields: [clientId], references: [id], onDelete: Restrict)
  
  items             Json     // Array of {productId, quantity, unitPrice}
  subtotal          Float
  tax               Float    @default(0)
  total             Float
  status            String   @default("draft") // draft, sent, paid, cancelled
  dueDate           DateTime?
  notes             String?  @db.Text
  
  createdBy         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  payments          StockInvoicePayment[]
  
  @@unique([orgId, invoiceNumber])
  @@index([clientId])
}

model StockInvoicePayment {
  id                String   @id @default(cuid())
  invoiceId         String
  invoice           StockInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  amount            Float
  paymentDate       DateTime
  paymentMethod     String   // cash, check, bank_transfer, card
  reference         String?
  notes             String?  @db.Text
  
  createdBy         String
  createdAt         DateTime @default(now())
  
  @@index([invoiceId])
}

model StockSale {
  id                String   @id @default(cuid())
  orgId             String
  org               Company  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  
  saleNumber        String
  clientId          String
  client            StockClient @relation(fields: [clientId], references: [id], onDelete: Restrict)
  
  items             StockSaleItem[]
  subtotal          Float
  tax               Float    @default(0)
  total             Float
  status            String   @default("completed") // draft, pending, completed, cancelled
  saleDate          DateTime @default(now())
  notes             String?  @db.Text
  
  createdBy         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@unique([orgId, saleNumber])
  @@index([clientId])
}

model StockSaleItem {
  id                String   @id @default(cuid())
  saleId            String
  sale              StockSale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  
  productId         String
  product           StockProduct @relation(fields: [productId], references: [id], onDelete: Restrict)
  
  quantity          Int
  unitPrice         Float
  total             Float
  
  @@index([saleId])
  @@index([productId])
}

// ==================== CLIENT COMPLAINTS ====================

model ClientComplaint {
  id                String   @id @default(cuid())
  orgId             String
  complaintId       String   @unique @db.VarChar(50)
  
  clientId          String
  client            StockClient @relation(fields: [clientId], references: [id], onDelete: Restrict)
  
  clientName        String
  clientNumber      String
  clientLocation    String?
  clientEmail       String?
  clientPhone       String?
  
  category          String   // poor_service, delayed_delivery, billing_issues, etc.
  priority          String   // low, medium, high, urgent
  status            String   @default("new") // new, under_review, assigned, in_progress, etc.
  title             String
  description       String   @db.Text
  attachments       Json?    // Array of URLs or file info
  
  submittedBy       String
  submittedByName   String?
  assignedTo        String?
  assignedToName    String?
  assignedUser      User?    @relation(fields: [assignedTo], references: [id], onDelete: SetNull)
  
  relatedTaskId     String?
  escalatedTo       String?
  escalationReason  String?  @db.Text
  
  communications    ComplaintCommunication[]
  internalNotes     ComplaintNote[]
  resolution        ComplaintResolution?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([orgId])
  @@index([clientId])
  @@index([status])
  @@index([priority])
}

model ComplaintCommunication {
  id                String   @id @default(cuid())
  complaintId       String
  complaint         ClientComplaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  
  senderUserId      String
  senderName        String?
  senderRole        String   // client, staff
  message           String   @db.Text
  attachments       Json?    // Array of URLs or file info
  
  createdAt         DateTime @default(now())
  
  @@index([complaintId])
}

model ComplaintNote {
  id                String   @id @default(cuid())
  complaintId       String
  complaint         ClientComplaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  
  userId            String
  userName          String?
  note              String   @db.Text
  
  createdAt         DateTime @default(now())
  
  @@index([complaintId])
}

model ComplaintResolution {
  id                String   @id @default(cuid())
  complaintId       String   @unique
  complaint         ClientComplaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  
  resolvedBy        String
  resolvedByName    String?
  satisfactionRating Int?    // 1-5 scale
  notes             String?  @db.Text
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([complaintId])
}

// ==================== MEETINGS ====================

model Meeting {
  id                String   @id @default(cuid())
  orgId             String
  org               Company  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  
  title             String
  description       String?  @db.Text
  scheduledAt       DateTime
  durationMinutes   Int      @default(60)
  meetingType       String   // video, audio, in-person
  meetingId         String   @unique @db.VarChar(100)
  meetingLink       String?
  password          String?
  requirePassword   Boolean  @default(false)
  
  status            String   @default("scheduled") // scheduled, in-progress, completed, cancelled
  
  organizerId       String
  organizer         User     @relation("MeetingOrganizer", fields: [organizerId], references: [id], onDelete: Restrict)
  
  attendees         MeetingAttendee[]
  
  actualStartTime   DateTime?
  actualEndTime     DateTime?
  agenda            String?  @db.Text
  transcript        String?  @db.LongText
  aiSummary         String?  @db.Text
  keyPoints         Json?    // Array of strings
  actionItems       MeetingActionItem[]
  
  recordingUrl      String?
  aiProcessed       Boolean  @default(false)
  aiProcessingStatus String? // pending, processing, completed, failed
  aiProcessingError String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([orgId])
  @@index([organizerId])
  @@index([scheduledAt])
}

model MeetingAttendee {
  id                String   @id @default(cuid())
  meetingId         String
  meeting           Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  displayName       String?
  isGuest           Boolean  @default(false)
  status            String   // invited, accepted, declined, tentative
  attended          Boolean  @default(false)
  
  joinedAt          DateTime?
  leftAt            DateTime?
  durationMinutes   Int?
  
  @@unique([meetingId, userId])
  @@index([meetingId])
}

model MeetingActionItem {
  id                String   @id @default(cuid())
  meetingId         String
  meeting           Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  
  description       String   @db.Text
  assignedTo        String   @db.VarChar(255)
  dueDate           DateTime?
  taskId            String?
  
  @@index([meetingId])
}

// ==================== LEAVE MANAGEMENT ====================

model LeaveRequest {
  id                String   @id @default(cuid())
  orgId             String
  org               Company  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  
  userId            String
  user              User     @relation(name: "leaveRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  
  type              String   // Annual, Sick, Maternity, Paternity, Unpaid, Other
  startDate         DateTime
  endDate           DateTime
  reason            String   @db.Text
  status            String   @default("pending") // pending, approved, rejected
  managerId         String?
  managerComment    String?  @db.Text
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([orgId])
  @@index([userId])
  @@index([status])
}

model LeaveBalance {
  id                String   @id @default(cuid())
  orgId             String
  org               Company  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  
  userId            String
  user              User     @relation(name: "leaveBalanceUser", fields: [userId], references: [id], onDelete: Cascade)
  
  year              Int
  annualTotal       Int      @default(21)
  annualUsed        Int      @default(0)
  sickTotal         Int      @default(14)
  sickUsed          Int      @default(0)
  maternityTotal    Int      @default(90)
  maternityUsed     Int      @default(0)
  paternityTotal    Int      @default(14)
  paternityUsed     Int      @default(0)
  unpaidUsed        Int      @default(0)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@unique([userId, year])
}

model Holiday {
  id                String   @id @default(cuid())
  orgId             String
  org               Company  @relation("holidays", fields: [orgId], references: [id], onDelete: Cascade)
  
  name              String
  date              DateTime
  countryCode       String
  type              String   @default("public") // public, company
  year              Int
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([orgId])
  @@index([countryCode, year])
}

// ==================== RECRUITMENT & JOBS ====================

model Job {
  id                String   @id @default(cuid())
  orgId             String
  org               Company  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  
  companyName       String
  positionIndex     Int
  title             String
  department        String
  location          String
  employmentType    String   @default("full-time") // full-time, part-time, contract, internship
  description       String   @db.Text
  requirements      Json?    // Array of strings
  responsibilities  Json?    // Array of strings
  salaryRange       Json?    // {min, max, currency}
  benefits          Json?    // Array of strings
  applicationDeadline DateTime?
  status            String   @default("draft") // draft, open, closed, filled
  
  createdBy         String
  shareLink         String   @unique
  views             Int      @default(0)
  applicationsCount Int      @default(0)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  applications      JobApplication[]
  
  @@index([orgId])
  @@index([status])
  @@index([employmentType])
}

model JobApplication {
  id                String   @id @default(cuid())
  orgId             String
  org               Company  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  
  jobId             String
  job               Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  formId            String
  applicantName     String
  applicantEmail    String
  applicantPhone    String?
  deviceFingerprint String?
  
  answers           Json?    // Mixed object from form submission
  uploadedFiles     Json?    // {fieldId: filepath} mapping
  resumeUrl         String?
  coverLetter       String?  @db.Text
  
  status            String   @default("pending") // pending, reviewing, shortlisted, rejected, hired
  source            String?  // utm_source or referrer
  rating            Int?     // 1-5
  
  notes             Json?    // Array of {note, created_by, created_at, type}
  timeline          Json?    // Array of {status, changed_by, changed_at, comment}
  
  submittedAt       DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([jobId])
  @@index([orgId])
  @@index([status])
  @@index([applicantEmail])
}

// ==================== TASKS & KPI ====================

model Task {
  id                String   @id @default(cuid())
  orgId             String
  org               Company  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  
  title             String
  description       String?  @db.Text
  priority          String   // low, medium, high, urgent
  status            String   @default("todo") // todo, in_progress, done, blocked
  assignedTo        String
  assignedUser      User     @relation(fields: [assignedTo], references: [id], onDelete: Restrict)
  dueDate           DateTime?
  
  createdBy         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([orgId])
  @@index([assignedTo])
  @@index([status])
}

model KPI {
  id                String   @id @default(cuid())
  orgId             String
  org               Company  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  
  name              String
  description       String?  @db.Text
  targetValue       Float
  currentValue      Float    @default(0)
  unit              String?
  owner             String?
  period            String   // daily, weekly, monthly, quarterly, annual
  status            String   @default("on_track") // on_track, at_risk, off_track
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@unique([orgId, name])
}

// ==================== AUDIT & LOGS ====================

model AuditLog {
  id                String   @id @default(cuid())
  orgId             String
  
  userId            String?
  action            String
  entityType        String   // User, StockProduct, etc.
  entityId          String
  changes           Json?    // Before/after values
  ipAddress         String?
  userAgent         String?
  
  createdAt         DateTime @default(now())
  
  @@index([orgId])
  @@index([userId])
  @@index([createdAt])
}

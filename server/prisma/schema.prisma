// Prisma schema file for MySQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("MYSQL_DATABASE_URL")
}

// ==================== CORE MODELS ====================

model Company {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique @db.VarChar(100)
  email             String   @unique @db.VarChar(255)
  phone             String?
  website           String?
  industry          String
  employeeCount     Int
  logo              String?
  country           String?
  state             String?
  city              String?
  countryCode       String?  @db.Char(2)
  
  // Branding
  primaryColor      String   @default("#2563eb")
  secondaryColor    String   @default("#059669")
  accentColor       String   @default("#f59e0b")
  backgroundColor   String   @default("#ffffff")
  textColor         String   @default("#1f2937")
  borderRadius      String   @default("0.5rem")
  fontFamily        String   @default("system-ui")
  buttonStyle       String   @default("rounded") // rounded, sharp, pill
  
  subscription      String   @default("starter") // starter, professional, enterprise
  status            String   @default("active") // active, suspended, inactive
  isFrozen          Boolean  @default(false)
  frozenReason      String?
  frozenAt          DateTime?
  frozenBy          String?
  
  // Email Configuration
  emailEnabled      Boolean  @default(false)
  emailVerified     Boolean  @default(false)
  emailFromName     String?
  emailFromEmail    String?
  emailPassword     String?

  emailConfig         Json?
  dispatchSmsSettings  Json?
  invoiceSettings      Json?
  setupProgress        Json?
  pageAccessSettings   Json?
  enabledPages         Json?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  users             User[]
  stockClients      StockClient[]
  stockProducts     StockProduct[]
  stockCategories   StockCategory[]
  // stockEntries      StockEntry[] // Temporarily commented due to FK conflicts
  stockSales        StockSale[]
  stockQuotations   StockQuotation[]
  stockInvoices     StockInvoice[]
  meetings          Meeting[]
  leaves            LeaveRequest[]
  leaveBalances     LeaveBalance[]
  holidays          Holiday[] @relation("holidays")
  jobs              Job[]
  jobApplications   JobApplication[]
  tasks             Task[]
  kpis              KPI[]
  
  @@unique([id, slug])
  @@index([status])
}

model User {
  id                String   @id @default(cuid())
  orgId             String
  org               Company  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  
  employeeId        String?  @unique @db.VarChar(50)
  firstName         String
  lastName          String
  email             String   @unique @db.VarChar(255)
  password          String
  
  role              String   @default("employee") // super_admin, company_admin, manager, employee, hr
  department        String?
  position          String?  // Job title
  managerId         String?  @db.VarChar(255)
  
  avatar            String?
  signatureUrl      String?
  phone             String?
  dateOfJoining     DateTime?
  status            String   @default("active") // active, inactive, pending
  
  salary            Float?
  bankAccountName   String?
  bankAccountNumber String?
  bankName          String?
  bankDetails       Json?
  
  promptStampOnPdf  Boolean  @default(false)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  meetings          Meeting[] @relation("MeetingOrganizer")
  meetingAttendees  MeetingAttendee[]
  leaveRequests     LeaveRequest[] @relation("leaveRequestUser")
  leaveBalances     LeaveBalance[] @relation("leaveBalanceUser")
  tasks             Task[]
  clientComplaints  ClientComplaint[]
  
  @@unique([orgId, email])
  @@index([role])
  @@index([status])
}

// ==================== STOCK MANAGEMENT ====================

model StockClient {
  id                String   @id @default(cuid())
  orgId             String
  org               Company  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  
  sourceName        String
  sourceNumber      String
  sourceLocation    String
  legalName         String
  kraPin            String?
  email             String?
  branchId          String?
  hasKraDetails     Boolean  @default(false)
  
  createdBy         String
  updatedBy         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  quotations        StockQuotation[]
  invoices          StockInvoice[]
  sales             StockSale[]
  complaints        ClientComplaint[]
  
  @@unique([orgId, sourceName, sourceNumber, sourceLocation])
  @@index([orgId])
}

model StockCategory {
  id                String   @id @default(cuid())
  orgId             String
  org               Company  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  
  name              String
  description       String?  @db.Text
  createdBy         String
  updatedBy         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  products          StockProduct[]
  
  @@unique([orgId, name])
}

model StockProduct {
  id                String   @id @default(cuid())
  orgId             String
  org               Company  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  
  categoryId        String
  category          StockCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  
  name              String
  description       String?  @db.Text
  sku               String
  unitPrice         Float
  quantity          Int      @default(0)
  reorderLevel      Int      @default(10)
  supplier          String?
  
  createdBy         String
  updatedBy         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // entries           StockEntry[]  // COMMENTED - StockEntry model commented
  salesItems        StockSaleItem[]
  
  @@unique([orgId, sku])
  @@index([categoryId])
}


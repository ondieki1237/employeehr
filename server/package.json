{
  "name": "elevate-backend",
  "version": "1.0.0",
  "description": "Backend API for Elevate - Employee Performance & Development Platform",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "concurrently \"npm run queue:worker\" \"npx tsx watch src/index.ts\"",
    "queue:worker": "npx tsx watch src/services/workers/syncWorker.ts",
    "create-owner": "npx tsx ./scripts/create_owner.ts",
    "prebuild": "npx prisma generate",
    "build": "npm run db:push && tsc",
    "prestart": "npm run db:push",
    "start": "node --experimental-specifier-resolution=node dist/index.js",
    "db:push": "npx ts-node src/scripts/runMigrations.ts",
    "db:migrate": "npx prisma migrate dev",
    "db:reset": "npx prisma migrate reset",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "@types/multer": "^2.0.0",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^4.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.0.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "nodemailer": "^6.9.7",
    "openai": "^6.15.0",
    "jspdf": "^2.5.1",
    "redis": "^4.7.0",
    "sanitize-html": "^2.11.0",
    "socket.io": "^4.8.2",
    "uuid": "^14.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^6.4.14",
    "@types/sanitize-html": "^2.9.3",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "concurrently": "^8.2.2",
    "eslint": "^8.55.0",
    "prisma": "^6.16.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}

# ERP Integration Environment Variables for Website Backends
# Copy this file to .env and fill in your values

# The ERP API base URL
# For production: https://backend.codewithseth.co.ke
# For local development: http://localhost:5010
ERP_API_BASE_URL=https://backend.codewithseth.co.ke

# Your organization ID (required)
# Get this from your ERP admin at: /admin/settings/system
# This identifies your tenant in the multi-tenant ERP
ERP_ORG_ID=your-organization-id-here

# Optional: API Key for future authentication
# (Currently not used, reserved for v2 implementation)
# ERP_API_KEY=your-api-key-here

# Optional: Rate limiting settings
# ERP_RATE_LIMIT_REQUESTS=100
# ERP_RATE_LIMIT_WINDOW_MS=60000

# Optional: Request timeout (milliseconds)
# ERP_REQUEST_TIMEOUT=10000

# Optional: Enable debug logging
# ERP_DEBUG=false
